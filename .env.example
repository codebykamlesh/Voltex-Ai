# ============================================
# Voltex AI — Environment Variables (Single File)
# ============================================
# Copy this file to .env and fill in your values.
# This one file powers BOTH the backend and the frontend.

# ---------- Database (MySQL) ----------
DATABASE_URL=mysql+aiomysql://user:password@host:3306/voltex_ai

# ---------- Backend ----------
BACKEND_SECRET_KEY=change-me-to-a-random-64-char-string
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---------- Firebase (Backend) ----------
# Paste your entire firebase-service-account.json as a single-line string.
# Required for production. Leave empty for local dev (mock mode).
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---------- Groq ----------
GROQ_API_KEY=gsk_your_groq_api_key_here

# ---------- Firebase (Frontend) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------- Optional ----------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
RATE_LIMIT_PER_MINUTE=30
